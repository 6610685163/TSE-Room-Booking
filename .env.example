# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# TU REST API Configuration (Requirement: FR-AUTH-02)
# Get Application-Key from https://restapi.tu.ac.th
TU_API_KEY=your-tu-api-key-here
TU_API_ENDPOINT=https://restapi.tu.ac.th/api/v1/auth/Ad/verify

# Database Configuration (optional - defaults to SQLite)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
# For PostgreSQL:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=tse_booking
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Email Configuration (Requirement: FR-NOTI-01, FR-NOTI-02)
# Using Gmail as example
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Email settings
DEFAULT_FROM_EMAIL=tse-booking@thammasat.ac.th
ADMIN_EMAIL=admin@thammasat.ac.th

# Security Settings (Requirement: NFR-SEC-*)
SESSION_COOKIE_SECURE=False  # Set to True in production
CSRF_COOKIE_SECURE=False     # Set to True in production
SECURE_SSL_REDIRECT=False    # Set to True in production
